# Configuration Kadio Cerveau

# Twilio (WhatsApp + Voix)
TWILIO_SID=your_twilio_sid
TWILIO_AUTH=your_twilio_auth_token
TWILIO_PHONE=+13022328291
TWILIO_WHATSAPP_NUMBER=whatsapp:+13022328291

# Square (Paiements + Rendez-vous)
SQUARE_APP_ID=your_square_app_id
SQUARE_SECRET=your_square_secret
SQUARE_TOKEN=your_square_token
SQUARE_LOCATION_ID=your_square_location_id

# Meta (Instagram + Facebook)
META_APP_ID=your_meta_app_id
META_SECRET=your_meta_secret
META_TOKEN=your_meta_token
META_PAGE_ID=your_meta_page_id
META_VERIFY_TOKEN=your_verify_token

# Resend (Email)
RESEND_API_KEY=your_resend_key

# OpenAI (Agent IA - OPTIONNEL, Kimi est préféré)
OPENAI_API_KEY=your_openai_key

# Kimi (Moonshot AI) - AGENT PRINCIPAL
KIMI_API_KEY=your_kimi_key

# Google (Gemini optionnel)
GOOGLE_API_KEY=your_google_key

# Othi (Propriétaire)
OTHI_PHONE=+15149195970
OTHI_TELEGRAM_ID=1543800301

# Base de données
DATABASE_URL=sqlite:///./kadio_cerveau.db

# Environnement
ENV=development
PORT=8000

# Frontend URL (pour OAuth callbacks)
FRONTEND_URL=https://kadio-cerveau.vercel.app
